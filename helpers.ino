// =================================================
// FORMAT TIME ΣΕ ΜΟΡΦΗ HH:mm:ss
// =================================================
// Μετατρέπει χρόνο από milliseconds (millis())
// σε μορφή ωρών:λεπτών:δευτερολέπτων (HH:mm:ss)
//
// Κάνει:
// - μετατροπή σε δευτερόλεπτα
// - υπολογισμό ωρών, λεπτών, δευτερολέπτων
// - μορφοποίηση με leading zeros (π.χ. 02:05:03)
//
// Χρησιμοποιείται για εμφάνιση χρόνου σε LCD / Cloud
// =================================================
String formatTime(unsigned long ms) {

  // Μετατροπή milliseconds → συνολικά δευτερόλεπτα
  unsigned long totalSeconds = ms / 1000;

  // Υπολογισμός ωρών
  int hours = totalSeconds / 3600;

  // Υπολογισμός λεπτών
  int minutes = (totalSeconds % 3600) / 60;

  // Υπολογισμός δευτερολέπτων
  int seconds = totalSeconds % 60;

  // Buffer για μορφή HH:mm:ss
  char buffer[9];

  // Μορφοποίηση με 2 ψηφία (leading zeros)
  sprintf(buffer, "%02d:%02d:%02d", hours, minutes, seconds);

  // Μετατροπή σε Arduino String
  return String(buffer);
}

// =================================================
// ΜΕΤΑΤΡΟΠΗ ΑΚΕΡΑΙΟΥ ΣΕ STRING ΜΕ ΣΤΑΘΕΡΟ ΠΛΑΤΟΣ
// =================================================
// Μετατρέπει έναν ακέραιο σε String με συγκεκριμένο πλάτος
//
// Παράμετροι:
// - value : ο αριθμός
// - width : συνολικοί χαρακτήρες εμφάνισης
//
// Κάνει:
// - δημιουργεί δυναμικό format (π.χ. "%-3d")
// - στοιχίζει αριστερά τον αριθμό
// - συμπληρώνει με κενά
//
// Χρησιμοποιείται για στοίχιση δεδομένων σε LCD
// =================================================
String formatInt(int value, int width) {

  // Buffer για αποθήκευση του αποτελέσματος
  char buffer[10];

  // Δημιουργία format string (π.χ. "%-3d")
  char format[10];
  sprintf(format, "%%-%dd", width);

  // Μορφοποίηση αριθμού
  sprintf(buffer, format, value);

  // Επιστροφή ως String
  return String(buffer);
}

// =================================================
// ΜΕΤΑΤΡΟΠΗ FLOAT ΣΕ STRING ΜΕ ΣΤΑΘΕΡΟ ΠΛΑΤΟΣ
// =================================================
// Μετατρέπει έναν δεκαδικό αριθμό σε String με
// συγκεκριμένο πλάτος και αριθμό δεκαδικών
//
// Παράμετροι:
// - value     : ο αριθμός
// - width     : συνολικό πλάτος χαρακτήρων
// - decimals  : πόσα δεκαδικά ψηφία
//
// Κάνει:
// - δημιουργεί δυναμικό format (π.χ. "%-6.1f")
// - στρογγυλοποιεί αυτόματα μέσω sprintf
// - στοιχίζει αριστερά
// - συμπληρώνει με κενά
//
// Χρησιμοποιείται για σωστή στοίχιση στην LCD
// =================================================
String formatFloat(float value, int width, int decimals) {

  // Buffer αποθήκευσης αποτελέσματος
  char buffer[20];

  // Δημιουργία format string (π.χ. "%-6.1f")
  char format[10];
  sprintf(format, "%%-%d.%df", width, decimals);

  // Μετατροπή αριθμού σε string
  sprintf(buffer, format, value);

  // Επιστροφή ως Arduino String
  return String(buffer);
}

// ================================================= 
// ROUND TO 1 DECIMAL PLACE 
// ================================================= 
// Στρογγυλοποιεί έναν αριθμό στο 1ο δεκαδικό ψηφίο
//
// Κάνει:
// - μεταφορά δεκαδικού (*10)
// - στρογγυλοποίηση (round)
// - επαναφορά (/10.0)
//
// Χρησιμοποιείται για καθαρή εμφάνιση τιμών (LCD / Cloud)
// ================================================= 
float round1(float value) { 
  return round(value * 10) / 10.0; 
}

// =================================================
// ΣΤΡΟΓΓΥΛΟΠΟΙΗΣΗ ΣΕ Ν ΔΕΚΑΔΙΚΑ ΨΗΦΙΑ
// =================================================
// Στρογγυλοποιεί έναν αριθμό σε συγκεκριμένα δεκαδικά ψηφία
//
// Παράμετροι:
// - value    : ο αριθμός
// - decimals : πλήθος δεκαδικών ψηφίων
//
// Κάνει:
// - υπολογισμό παράγοντα (10^decimals)
// - μεταφορά δεκαδικού
// - στρογγυλοποίηση (round)
// - επαναφορά τιμής
//
// Χρησιμοποιείται για έλεγχο ακρίβειας και καθαρή εμφάνιση
// =================================================
float roundFloat(float value, int decimals) {

  // Υπολογισμός παράγοντα (10^decimals)
  float factor = pow(10, decimals);

  // Στρογγυλοποίηση και επαναφορά
  return round(value * factor) / factor;
}
