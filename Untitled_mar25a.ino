// =================================================
// SETUP – ΑΡΧΙΚΟΠΟΙΗΣΗ ΣΥΣΤΗΜΑΤΟΣ
// =================================================
// Αρχικοποιεί όλο το σύστημα:
//
// - Serial επικοινωνία
// - Pins (αισθητήρες / servo / LED)
// - I2C συσκευές
// - LCD
// - Sensors (DHT, SEN, HuskyLens, GNSS)
// - Cloud
//
// Εκτελείται ΜΟΝΟ μία φορά στην εκκίνηση
// =================================================
void setup() {

  // Εκκίνηση Serial επικοινωνίας (debug)
  Serial.begin(115200);
  delay(serialStartupDelay);

  // Εκκίνηση Serial2 (HuskyLens)
  Serial2.begin(9600);
  delay(serialStartupDelay);
  
  // Σύνδεση servo στα pins
  pinMode(servoHoriPin, OUTPUT);
  pinMode(servoVertPin, OUTPUT);

  // Θέση εκκίνησης servo
  controlServoPWM(servoHoriPin, servoHoriPos);
  controlServoPWM(servoVertPin, servoVertPos);

  // Ορισμός pin ως έξοδοι
  pinMode(ena_1, OUTPUT);
  pinMode(enb_1, OUTPUT);

  pinMode(motor1pin1, OUTPUT);
  pinMode(motor1pin2, OUTPUT);

  pinMode(motor2pin1, OUTPUT);
  pinMode(motor2pin2, OUTPUT);

  pinMode(ena_2, OUTPUT);
  pinMode(enb_2, OUTPUT);

  pinMode(motor3pin1, OUTPUT);
  pinMode(motor3pin2, OUTPUT);

  pinMode(motor4pin1, OUTPUT);
  pinMode(motor4pin2, OUTPUT);

  pinMode(frontCurtainPin1, OUTPUT);
  pinMode(frontCurtainPin2, OUTPUT);

  pinMode(rearCurtainPin1, OUTPUT);
  pinMode(rearCurtainPin2, OUTPUT);

  pinMode(leftCurtainPin1, OUTPUT);
  pinMode(leftCurtainPin2, OUTPUT);

  pinMode(rightCurtainPin1, OUTPUT);
  pinMode(rightCurtainPin2, OUTPUT);

  pinMode(cloudLedGreenPin, OUTPUT);
  pinMode(cloudLedRedPin, OUTPUT);
  digitalWrite(cloudLedGreenPin, HIGH);
  digitalWrite(cloudLedRedPin, HIGH);

  pinMode(lightPin, OUTPUT);
  digitalWrite(lightPin, LOW);

  pinMode(fanPin, OUTPUT);
  digitalWrite(fanPin, LOW);

  pinMode(buzzerPin, OUTPUT);
  digitalWrite(buzzerPin, LOW);

  // Ορισμός pin ως είσοδος
  // Τέσσερις LDR γύρω από τον αισθητήρα
  pinMode(ldrltPin, INPUT);
  pinMode(ldrrtPin, INPUT);
  pinMode(ldrldPin, INPUT);
  pinMode(ldrrdPin, INPUT);

  // Αισθητήρας βροχής
  pinMode(rainDropPin, INPUT);

  // Διακόπτης
  pinMode(switchLightPin, INPUT_PULLUP);
  pinMode(switchCloudPin, INPUT_PULLUP);

  // Δίνει διαφορετικά νούμερα κάθε φορά 
  randomSeed(analogRead(A5));  // ← εδώ

  // ===== I2C =====
  Wire.begin();
  delay(i2cStartupDelay);

  Wire1.begin();
  delay(i2cStartupDelay);

  // ===== LCD =====
  lcd.init();
  lcd.backlight();

  // Intro οθόνη
  displayIntro();

  // Test servo κίνησης
  testServoSweep();
  
  // Καθαρισμός οθόνης
  lcd.clear();

  displayLineCentered(0, "*INITIALISE*");

  // ===== DHT20 =====
  if (!useFakeDataDHT) {

    int retries = 0;

    // Προσπάθεια εκκίνησης αισθητήρα
    while (dht20.begin()) {  
      Serial.print("DHT20 failed - ");
      Serial.println(retries + 1);

      delay(sensorRetryDelay);
      retries++;
      
      // fallback σε fake mode
      if (retries >= maxFailedAttempts) {
        useFakeDataDHT = true;
        break;
      }
    }
    
    if (!useFakeDataDHT) {
      Serial.println("DHT20 connected successfully");
      displayLineCentered(1, "DHT20 connected");
    } else {
      Serial.println("Switching to FAKE DHT mode");
      displayLineCentered(1, "DHT20 failed");
    }

    delay(modeMessageStartInterval / 2);

  } else {
    Serial.println("Switching to FAKE DHT mode");
    displayLineCentered(1, "DHT20 FAKE mode");
    delay(modeMessageStartInterval / 2);
  }

  // ===== SEN0516 =====
  if (!useFakeDataSEN) {

    int retries = 0;

    // Προσπάθεια εκκίνησης αισθητήρα
    while (icp.begin()) {

      Serial.print("SEN0516 failed - ");
      Serial.println(retries + 1);

      delay(sensorRetryDelay);
      retries++;

      // fallback σε fake mode
      if (retries >= maxFailedAttempts) {
        useFakeDataSEN = true;
        break;
      }
    }
    
    if (!useFakeDataSEN) {

      icp.setWorkPattern(icp.eNormal);

      Serial.println("SEN0516 connected successfully");
      displayLineCentered(2, "SEN0516 connected");

    } else {

      Serial.println("Switching to FAKE SEN mode");
      displayLineCentered(2, "SEN0516 failed");
    }

    delay(modeMessageStartInterval / 2);

  } else {

    Serial.println("Switching to FAKE SEN mode");
    displayLineCentered(2, "SEN0516 FAKE mode");
    delay(modeMessageStartInterval / 2);
  }

  // ===== HUSKYLENS =====
  if (!useFakeDataHL) {

    int retries = 0;
      
    // Προσπάθεια εκκίνησης κάμερας
    while (!huskylens.begin(Serial2)){

      Serial.print("HuskyLens failed - ");
      Serial.println(retries + 1);

      delay(sensorRetryDelay / 3);
      retries++;

      // fallback σε fake mode
      if (retries >= maxFailedAttempts) {
        useFakeDataHL = true;
        break;
      }
    }
    
    if (!useFakeDataHL) {

      Serial.println("HuskyLens connected successfully");
      displayLineCentered(3, "HuskyLens connected");

    } else {

      Serial.println("Switching to FAKE HuskyLens mode");
      displayLineCentered(3, "HuskyLens failed");
    }

    delay(modeMessageStartInterval / 2);

  } else {

    Serial.println("Switching to FAKE HuskyLens mode");
    displayLineCentered(3, "HuskyLens FAKE mode");
    delay(modeMessageStartInterval / 2);
  }

  // ===== CLOUD =====
  
  // Έλεγχος διακόπτη ενεργοποίησης cloud
  readCloudSwitch();
  delay(modeMessageStartInterval);

  // Αν επιτρέπεται η χρήση Cloud
  if(!offlineMode) {
    // Αρχικοποίηση cloud μεταβλητών
    initProperties();

    // Αρχικοποίηση cloud
    initCloud();
  }
  
  // Update LED με βάση κατάσταση
  updateCloudStatusLEDs();
  
  // Τελικός καθαρισμός LCD
  lcd.clear();

  // Έλεγχος διακόπτη ενεργοποίησης tracking
  lastSwitchState = !digitalRead(switchLightPin);
  readTrackingSwitch();
  
  delay(modeMessageStartInterval);
}

// =================================================
// MAIN LOOP
// =================================================
// Κεντρικός βρόχος προγράμματος (τρέχει συνεχώς)
//
// Περιλαμβάνει:
// - Χρονισμό (millis)
// - Cloud διαχείριση
// - Light tracking & κίνηση
// - Sensors (φως / βροχή)
// - LCD display
// - HuskyLens
// - Cloud commands
// =================================================
void loop() {

  // Τρέχων χρόνος (βάση για όλα τα timers)
  myTime = millis();

  // Μετατροπή uptime σε μορφή HH:mm:ss
  uptime = formatTime(myTime);
  
  
  // =================================================
  // CLOUD SYSTEM
  // =================================================

  // Αν επιτρέπεται η χρήση Cloud
  if(!offlineMode) {
    // Ενημερώνει την μεταβλητη Cloud
    cloudUptime = uptime;
  
    // Διαχείριση σύνδεσης Cloud (connect / reconnect / offline)
    updateCloudConnection();
  }
    
  // Ενημέρωση LED κατάστασης Cloud
  updateCloudStatusLEDs();
  

  // =================================================
  // LIGHT TRACKING SYSTEM
  // =================================================

  // Παρακολούθηση φωτός (υπολογισμοί LDR)
  trackLightSensors();

  // Κίνηση servo οριζόντια
  // controlServoPWM(servoHoriPin, servoHoriPos);
  
  // Κίνηση servo κάθετα
  // controlServoPWM(servoVertPin, servoVertPos);

  // Έλεγχος διακόπτη ενεργοποίησης tracking
  readTrackingSwitch();

  // Κίνηση μοτέρ βάσει φωτός (αν είναι ενεργό)
  if (lightTrackingEnabled) {
    controlMotorsByLight();
  }
  

  // =================================================
  // ENVIRONMENT SYSTEM
  // =================================================
  
  // Συλλογή τιμών απο αισθητήρες
  readAllSensors();
  
  // Έλεγχος βοηθητικού φωτισμού (LIGHT)
  controlLight();

  // Έλεγχος βοηθητικού ανεμιστήρα (FAN)
  controlFan();

  // Έλεγχος βροχής
  controlRain();

  // Έλεγχος ειδοποιήσεων
  controlBuzzer();

  // =================================================
  // DISPLAY SYSTEM
  // =================================================

  // Εμφάνιση τιμών φωτός στην LCD
  displayLightData();
  
  // Εμφάνιση περιβαλλοντικών δεδομένων
  displayEnvironmentData();

  // Διαχείριση προσωρινών μηνυμάτων LCD
  updateDisplayMessages();


  // =================================================
  // AI SYSTEM (HUSKYLENS)
  // =================================================

  // Επεξεργασία δεδομένων από HuskyLens
  updateHuskyLens();


  // =================================================
  // CLOUD DATA & COMMANDS
  // =================================================

  // Αν επιτρέπεται η χρήση Cloud
  if(!offlineMode) {
    // Ενημέρωση τιμών στο Arduino Cloud
    updateCloudData();
    
    // Έλεγχος φωτισμού μέσω Cloud
    controlCloudLight();

    // Έλεγχος ανεμιστήρα μέσω Cloud
    controlCloudFan();
  
    // Έλεγχος κίνησης μέσω Cloud
    controlCloudMovement();
  
    // Έλεγχος κουρτινών μέσω Cloud
    controlCloudCurtains();
  }
}


